@page "/libros"

@using BlazorCrud.Repositorio
@using BlazorCrud_Proyecto01.Modelos
@inject IRepositorio Repositorio


<h3>Lista los Libros</h3>

<h3 class="text-center">
    Actividad Sumativa - Creación de aplicación Contenerizada en Docker
    @* <a href="https://render2web.com" target="_blank"> www.render2web.com</a> *@
</h3>

<div class="card">
    <div class="card-header">
        <div class="row">
            <div class="col-12">
                <h2 class="text-dark">Lista de Libros</h2>
            </div>
        </div>
    </div>
    <div class="card-body">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Título</th>
                    <th>Descripción</th>
                    <th>Autor</th>
                    <th>Páginas</th>
                    <th>Precio</th>
                    <th>Fecha de Creación</th>
                    <th>Acciones</th>
                    <th>Tipo Libro</th>
                    <th>Estado</th>


                </tr>
            </thead>
            <tbody>
                @foreach (var libro in listaLibros)
                {
                    <tr>
                        <td>@libro.Id</td>
                        <td>@libro.Titulo</td>
                        <td>@libro.Descripcion</td>
                        <td>@libro.Autor</td>
                        <td>@libro.Paginas</td>
                        <td>@libro.Precio</td>
                        <td>@libro.FechaCreacion</td>
                        <td>Novela</td>
                        <td>True (Activo)</td>
                        <td>
                            <a href="editar-libro/@libro.Id" class="btn btn-success btn-sm">
                                <span class="oi oi-plus" aria-hidden="true"></span> Editar</a>
                            <button @onclick="@( () => BorrarLibro(libro.Id))" class="btn btn-danger btn-sm">
                                <span class="oi oi-delete" aria-hidden="true"></span> Borrar</button>
                        </td>
                    </tr>
                }

            </tbody>
        </table>
    </div>
</div>

@code {
    private List<Libro> listaLibros = new List<Libro>();

    protected override async Task OnParametersSetAsync()
    {
        listaLibros = await Repositorio.GetLibros();
    }

    private async Task BorrarLibro(int libroId)
    {
        await Repositorio.EliminarLibro(libroId);

        //Actualizar el modelo  de libros para que recargue la lista de libros
        listaLibros = await Repositorio.GetLibros();
    }
}
